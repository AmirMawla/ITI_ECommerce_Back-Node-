# DB & JWT CONFIGURATION
PORT=Port number for this API e.g. 3000
MONGODB_URI=MongoDB connection URI without database name at the end use local or Atlas string
DB_NAME=Name of the MongoDB database the app connects to
JWT_SECRET=Long random secret used to sign and verify JWT tokens

# Seeds: npm run seed:admin | npm run seed:all | npm run seed:reset (wipes demo data)
SEED_ADMIN_EMAIL=admin email for full seed and seed admin
SEED_ADMIN_PASSWORD=admin password min 8 chars
SEED_ADMIN_NAME=admin display name min 3 chars
SEED_USER_PASSWORD=shared password for all demo sellers and customers in seed all

# payment gateway Configuration
KASHIER_URL=Kashier API base URL from Kashier docs test or live
KASHIER_API_KEY=Your Kashier API key from the merchant dashboard
KASHIER_SECRET_KEY=Your Kashier secret key for signing and verifying webhooks
KASHIER_MERCHANT_ID=Your Kashier merchant ID
WEBHOOK_URL=Public HTTPS URL where this server receives Kashier webhooks use ngrok locally if needed

# Email Configuration
SMTP_HOST=Outgoing mail server hostname e.g. smtp.gmail.com
SMTP_PORT=SMTP port as number e.g. 587 for TLS
SMTP_USER=SMTP account username usually full email address
SMTP_PASS=SMTP password or app password from your provider
EMAIL_FROM=Sender name and email shown to recipients e.g. AppName your@email.com
FRONTEND_URL=Frontend app base URL for email links no trailing slash

# RabbitMQ Configuration
RABBITMQ_URL=RabbitMQ AMQP connection URL e.g. amqp://localhost:5672 or cloud URL
EMAIL_QUEUE_NAME=Name of the queue used for email jobs must match the worker


# ImageKit Configurations
IMAGEKIT_PUBLIC_KEY=ImageKit public API key from ImageKit dashboard
IMAGEKIT_PRIVATE_KEY=ImageKit private API key keep confidential
IMAGEKIT_URL_ENDPOINT=ImageKit URL endpoint e.g. https://ik.imagekit.io/your_imagekit_id
